{
  "name": "@mackerel/mcp-server",
  "version": "0.4.0",
  "packageManager": "pnpm@10.12.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "A Model Context Protocol server for interacting with Mackerel",
  "main": "build/index.js",
  "bin": {
    "mcp-server": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector -e MACKEREL_APIKEY=$MACKEREL_APIKEY tsx src/index.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "license": "Apache-2.0",
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "types": "build/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/mackerelio-labs/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mackerelio-labs/mcp-server/issues"
  },
  "author": "Mackerel <platform+mackerel@hatena.ne.jp> (http://mackerel.io/)",
  "homepage": "https://github.com/mackerelio-labs/mcp-server#readme",
  "keywords": [
    "mackerel",
    "model-context-protocol",
    "mcp"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
